# Rust build artifacts (any crate, including capi/ and wasm/)
target/
**/*.rs.bk
*.pdb

# Cargo files
# Note: Cargo.lock is tracked for reproducible builds (recommended for binaries)

# Fuzzing artifacts
/fuzz/target/
/fuzz/corpus/
/fuzz/artifacts/

# Documentation build output and dependencies (sources are tracked)
docs/node_modules/
docs/build/
docs/.docusaurus/

# Testing
*.profraw
*.gcda
*.gcno

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.iml

# OS files
Thumbs.db
.DS_Store

# Coverage reports
/coverage/
*.lcov
tarpaulin-report.html

# Benchmark results
/target/criterion/

# Environment files
.env
.env.local

# Temporary files
*.tmp
*.temp
*.log

# Build artifacts from examples
/examples/target/
